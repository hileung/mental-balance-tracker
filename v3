<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Mental Balance Tracker v1</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    :root {
      --bg: #050816;
      --bg-elevated: #0b1020;
      --bg-elevated-soft: #0f1629;
      --accent: #22c55e;
      --accent-soft: rgba(34, 197, 94, 0.08);
      --accent-strong: rgba(34, 197, 94, 0.18);
      --accent-border: rgba(34, 197, 94, 0.6);
      --accent-glow: rgba(34, 197, 94, 0.35);
      --accent-muted: rgba(34, 197, 94, 0.25);
      --text-main: #e5e7eb;
      --text-soft: #9ca3af;
      --text-softer: #6b7280;
      --border-subtle: rgba(148, 163, 184, 0.3);
      --border-strong: rgba(148, 163, 184, 0.7);
      --danger: #f97373;
      --danger-soft: rgba(248, 113, 113, 0.08);
      --warning: #facc15;
      --warning-soft: rgba(250, 204, 21, 0.08);
      --info: #38bdf8;
      --info-soft: rgba(56, 189, 248, 0.08);
      --card-radius: 18px;
      --chip-radius: 999px;
      --shadow-soft: 0 18px 45px rgba(15, 23, 42, 0.7);
      --shadow-strong: 0 24px 60px rgba(15, 23, 42, 0.95);
      --shadow-focus: 0 0 0 1px rgba(148, 163, 184, 0.6), 0 18px 45px rgba(15, 23, 42, 0.7);
      --shadow-accent: 0 0 0 1px rgba(34, 197, 94, 0.7), 0 0 40px rgba(34, 197, 94, 0.2);
      --input-radius: 999px;
      --transition-fast: 0.15s ease-out;
      --transition-med: 0.22s ease;
      --glass-border: rgba(148, 163, 184, 0.45);
      --glass-bg: rgba(15, 23, 42, 0.8);
      --glass-accent-border: rgba(34, 197, 94, 0.8);
      --glass-accent-bg: rgba(15, 23, 42, 0.95);
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "SF Pro Text",
        "Segoe UI", sans-serif;
      background: radial-gradient(circle at top, #020617 0, #020617 45%, #020617 100%);
      color: var(--text-main);
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    body {
      min-height: 100vh;
      padding: 24px 16px 32px;
      display: flex;
      justify-content: center;
    }

    .app-shell {
      width: 100%;
      max-width: 1120px;
      position: relative;
      z-index: 1;
    }

    .bg-orbit {
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: 0.9;
      mix-blend-mode: screen;
      z-index: 0;
    }

    .bg-orbit::before,
    .bg-orbit::after {
      content: "";
      position: absolute;
      border-radius: 50%;
      filter: blur(50px);
      opacity: 0.55;
    }

    .bg-orbit::before {
      width: 420px;
      height: 420px;
      background: radial-gradient(circle, rgba(34, 197, 94, 0.14), transparent 60%);
      top: -140px;
      left: -40px;
    }

    .bg-orbit::after {
      width: 420px;
      height: 420px;
      background: radial-gradient(circle, rgba(56, 189, 248, 0.12), transparent 60%);
      bottom: -80px;
      right: -40px;
    }

    .main-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.9fr);
      gap: 18px;
      align-items: flex-start;
    }

    @media (max-width: 980px) {
      body {
        padding: 16px 12px 28px;
      }

      .main-grid {
        grid-template-columns: minmax(0, 1fr);
      }

      .sidebar-column {
        order: -1;
      }
    }

    .card {
      background: linear-gradient(135deg, rgba(15, 23, 42, 0.85), rgba(17, 24, 39, 0.95));
      border-radius: var(--card-radius);
      border: 1px solid var(--border-subtle);
      box-shadow: var(--shadow-soft);
      padding: 16px 18px 15px;
      position: relative;
      overflow: hidden;
    }

    .card::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at top left, rgba(34, 197, 94, 0.06), transparent 58%);
      opacity: 0.9;
      pointer-events: none;
    }

    .card-inner {
      position: relative;
      z-index: 1;
    }

    .header-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 10px;
    }

    .page-title-block {
      display: flex;
      flex-direction: column;
      gap: 3px;
    }

    .title-row {
      display: flex;
      align-items: center;
      gap: 11px;
      flex-wrap: wrap;
    }

    .title-badge {
      padding: 3px 12px 3px 4px;
      border-radius: 999px;
      border: 1px solid rgba(34, 197, 94, 0.45);
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: radial-gradient(circle at 0 0, rgba(34, 197, 94, 0.2), rgba(15, 23, 42, 0.96));
      box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.9);
    }

    .title-badge-orbit {
      width: 18px;
      height: 18px;
      border-radius: 999px;
      background: radial-gradient(circle at 30% 25%, #bbf7d0, #22c55e 40%, #166534 72%);
      box-shadow: 0 0 0 1px rgba(22, 163, 74, 0.75), 0 0 0 6px rgba(34, 197, 94, 0.2),
        0 0 26px rgba(34, 197, 94, 0.45);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    .title-badge-orbit::after {
      content: "";
      position: absolute;
      inset: 2px;
      border-radius: inherit;
      border: 1px solid rgba(240, 253, 250, 0.42);
    }

    .title-badge-orbit-dot {
      width: 5px;
      height: 5px;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.1);
      box-shadow: inset 0 0 0 1px rgba(240, 253, 244, 0.65);
    }

    .title-badge-label {
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(209, 250, 229, 0.9);
      font-weight: 600;
    }

    .page-title {
      margin: 0;
      font-size: 20px;
      letter-spacing: 0.01em;
      color: #f9fafb;
    }

    .page-subtitle {
      margin: 0;
      font-size: 11.5px;
      color: var(--text-soft);
      max-width: 420px;
      line-height: 1.5;
    }

    .date-chip {
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.35);
      background: radial-gradient(circle at 0 0, rgba(148, 163, 184, 0.22), rgba(15, 23, 42, 0.96));
      font-size: 10.5px;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: #e5e7eb;
      white-space: nowrap;
    }

    .date-dot {
      width: 6px;
      height: 6px;
      border-radius: 999px;
      background: linear-gradient(135deg, #22c55e, #4ade80);
      box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.2);
    }

    .date-label {
      letter-spacing: 0.09em;
      text-transform: uppercase;
      color: var(--text-soft);
    }

    .date-value {
      font-variant-numeric: tabular-nums;
    }

    .layout-two-column {
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 1.1fr);
      gap: 14px;
      align-items: flex-start;
    }

    @media (max-width: 900px) {
      .layout-two-column {
        grid-template-columns: minmax(0, 1fr);
      }
    }

    .card-section {
      padding: 11px 12px 12px;
      border-radius: 14px;
      border: 1px solid rgba(55, 65, 81, 0.8);
      background: radial-gradient(circle at 0 0, rgba(31, 41, 55, 0.58), rgba(17, 24, 39, 0.95));
      position: relative;
      margin-bottom: 8px;
    }

    .card-section--accent {
      border-color: rgba(34, 197, 94, 0.65);
      background: radial-gradient(circle at 0 0, rgba(22, 163, 74, 0.42), rgba(15, 23, 42, 0.96));
      box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.92), 0 18px 36px rgba(15, 23, 42, 0.9),
        0 0 30px rgba(34, 197, 94, 0.32);
    }

    .card-section--soft {
      border-color: rgba(148, 163, 184, 0.4);
      background: radial-gradient(circle at 0 0, rgba(15, 23, 42, 0.88), rgba(15, 23, 42, 0.98));
    }

    .card-section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 8px;
    }

    .section-title-row {
      display: flex;
      align-items: center;
      gap: 9px;
    }

    .section-pill {
      padding: 2px 8px 2px 3px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #e5e7eb;
    }

    .section-pill--accent {
      border: 1px solid rgba(34, 197, 94, 0.7);
      background: linear-gradient(135deg, rgba(22, 163, 74, 0.3), rgba(15, 23, 42, 0.98));
      box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.9);
    }

    .section-pill--neutral {
      border: 1px solid rgba(148, 163, 184, 0.8);
      background: linear-gradient(135deg, rgba(31, 41, 55, 0.8), rgba(15, 23, 42, 0.98));
    }

    .section-pill-orbit {
      width: 15px;
      height: 15px;
      border-radius: 999px;
      background: radial-gradient(circle at 30% 25%, #bbf7d0, #22c55e 45%, #166534 78%);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 0 0 1px rgba(22, 163, 74, 0.7), 0 0 22px rgba(34, 197, 94, 0.4);
      position: relative;
    }

    .section-pill-orbit::after {
      content: "";
      position: absolute;
      inset: 1px;
      border-radius: inherit;
      border: 1px solid rgba(240, 253, 250, 0.4);
    }

    .section-pill-orbit-inner {
      width: 4px;
      height: 4px;
      border-radius: inherit;
      background: rgba(15, 23, 42, 0.3);
      box-shadow: inset 0 0 0 1px rgba(240, 253, 244, 0.9);
    }

    .section-title {
      margin: 0;
      font-size: 15px;
      font-weight: 600;
      letter-spacing: 0.02em;
      display: flex;
      align-items: baseline;
      gap: 6px;
    }

    .section-title-sub {
      font-size: 11px;
      font-weight: 400;
      color: var(--text-soft);
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .section-caption {
      margin: 0;
      font-size: 11px;
      color: #9ca3af;
    }

    .section-caption span {
      color: #e5e7eb;
      font-weight: 500;
    }

    .micro-grid-3 {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    @media (max-width: 640px) {
      .micro-grid-3 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    .micro-card {
      border-radius: 13px;
      padding: 8px 9px 8px;
      border: 1px solid rgba(55, 65, 81, 0.9);
      background: radial-gradient(circle at 0 0, rgba(31, 41, 55, 0.8), rgba(15, 23, 42, 0.98));
      position: relative;
    }

    .micro-card--accent {
      border-color: rgba(34, 197, 94, 0.75);
      background: radial-gradient(circle at 0 0, rgba(22, 163, 74, 0.4), rgba(15, 23, 42, 0.98));
      box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.9), 0 0 26px rgba(34, 197, 94, 0.5);
    }

    .micro-label-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      margin-bottom: 5px;
    }

    .micro-label {
      font-size: 11px;
      font-weight: 500;
      color: #f9fafb;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .micro-context {
      font-size: 10px;
      color: var(--text-soft);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .micro-body {
      font-size: 11px;
      color: var(--text-soft);
      line-height: 1.5;
    }

    .input-row {
      display: flex;
      gap: 8px;
      margin-top: 8px;
      align-items: center;
    }

    .input-chip {
      flex: 1;
      border-radius: var(--input-radius);
      border: 1px solid rgba(148, 163, 184, 0.65);
      background: radial-gradient(circle at 0 0, rgba(15, 23, 42, 0.9), rgba(15, 23, 42, 0.98));
      padding: 6px 9px;
      display: flex;
      align-items: center;
      gap: 7px;
      font-size: 11px;
      color: #d1d5db;
    }

    .input-chip-label {
      text-transform: uppercase;
      letter-spacing: 0.09em;
      font-weight: 500;
      color: var(--text-soft);
    }

    .input-chip-value {
      opacity: 0.9;
    }

    .input-chip--editable {
      cursor: text;
    }

    .input-chip--editable:hover {
      border-color: rgba(209, 213, 219, 0.9);
    }

    .toggle-pill {
      border-radius: 999px;
      border: 1px solid rgba(34, 197, 94, 0.7);
      background: radial-gradient(circle at 0 0, rgba(22, 163, 74, 0.4), rgba(15, 23, 42, 0.98));
      display: inline-flex;
      align-items: center;
      padding: 2px 4px;
      gap: 2px;
      cursor: pointer;
      position: relative;
      min-width: 76px;
      justify-content: space-between;
    }

    .toggle-pill-switch {
      width: 18px;
      height: 18px;
      border-radius: 999px;
      background: radial-gradient(circle at 30% 25%, #bbf7d0, #22c55e 45%, #166534 78%);
      box-shadow: 0 0 0 1px rgba(22, 163, 74, 0.75), 0 0 0 6px rgba(34, 197, 94, 0.22);
    }

    .toggle-pill-labels {
      display: flex;
      align-items: center;
      gap: 5px;
      padding: 0 4px;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .toggle-pill-label-primary {
      color: #bbf7d0;
    }

    .toggle-pill-label-secondary {
      color: rgba(209, 213, 219, 0.7);
    }

    .story-chip {
      margin-top: 6px;
      border-radius: 13px;
      border: 1px dashed rgba(156, 163, 175, 0.9);
      background: radial-gradient(circle at 0 0, rgba(15, 23, 42, 0.9), rgba(31, 41, 55, 0.98));
      padding: 6px 8px 6px;
      display: flex;
      gap: 8px;
      align-items: flex-start;
    }

    .story-chip-label {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.09em;
      color: rgba(209, 213, 219, 0.9);
      padding-top: 1px;
      white-space: nowrap;
    }

    .story-chip-body {
      font-size: 11px;
      color: var(--text-soft);
      line-height: 1.5;
    }

    .daily-checklist {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      margin-top: 6px;
    }

    @media (max-width: 900px) {
      .daily-checklist {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    .check-item {
      border-radius: 999px;
      border: 1px solid rgba(75, 85, 99, 0.9);
      background: radial-gradient(circle at 0 0, rgba(31, 41, 55, 0.9), rgba(15, 23, 42, 0.98));
      padding: 5px 8px;
      font-size: 11px;
      color: #e5e7eb;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .check-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.7);
      box-shadow: inset 0 0 0 1px rgba(15, 23, 42, 0.9);
      background: radial-gradient(circle at 0 0, rgba(15, 23, 42, 0.9), rgba(31, 41, 55, 0.95));
    }

    .check-label-main {
      font-weight: 500;
    }

    .check-label-sub {
      font-size: 10px;
      color: var(--text-soft);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .evening-section {
      margin-top: 4px;
    }

    .evening-row {
      display: grid;
      grid-template-columns: 1.1fr 0.95fr;
      gap: 10px;
      margin-top: 6px;
    }

    @media (max-width: 800px) {
      .evening-row {
        grid-template-columns: minmax(0, 1fr);
      }
    }

    .evening-card {
      border-radius: 13px;
      border: 1px solid rgba(55, 65, 81, 0.9);
      background: radial-gradient(circle at 0 0, rgba(15, 23, 42, 0.9), rgba(17, 24, 39, 0.98));
      padding: 7px 8px 7px;
    }

    .evening-card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 4px;
      gap: 8px;
    }

    .evening-tag {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #9ca3af;
      font-weight: 500;
    }

    .evening-tag-strong {
      color: #e5e7eb;
    }

    .evening-chip {
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.8);
      background: radial-gradient(circle at 0 0, rgba(31, 41, 55, 0.85), rgba(15, 23, 42, 0.98));
      padding: 3px 8px;
      font-size: 10px;
      color: #d1d5db;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .evening-chip-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: linear-gradient(135deg, #22c55e, #4ade80);
      box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.25);
    }

    .evening-body {
      font-size: 11px;
      color: var(--text-soft);
      line-height: 1.5;
    }

    .evening-metric-row {
      display: flex;
      gap: 6px;
      margin-top: 6px;
      flex-wrap: wrap;
    }

    .metric-pill {
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.55);
      background: radial-gradient(circle at 0 0, rgba(15, 23, 42, 0.95), rgba(15, 23, 42, 0.98));
      padding: 4px
